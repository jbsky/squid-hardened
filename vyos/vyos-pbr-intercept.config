# =====================================================================
#  VyOS configure-mode commands -- PBR + In-Container REDIRECT
#  Transparent HTTPS Interception (ssl-bump) with Podman Squid
#
#  This approach routes packets intact into the container's network
#  namespace via PBR, then applies nft REDIRECT inside that netns.
#  Unlike host-level DNAT, SO_ORIGINAL_DST works correctly.
#
#  See docs/vyos-transparent-proxy.md for full explanation.
#
#  Placeholders (replace with your values):
#    <CLIENT_SUBNET>  — e.g., 192.168.10.0/24
#    <CLIENT_IFACE>   — e.g., eth0.10
#    <PROXY_IP>       — e.g., 172.20.0.10
#    <PROXY_NETWORK>  — e.g., 172.20.0.0/24
#    <PROXY_BRIDGE>   — e.g., pod-webproxy
#    <NETWORK_NAME>   — e.g., webproxy
#    <WAN_IFACE>      — e.g., eth1
#    <PBR_TABLE>      — e.g., 100
#    <PBR_MARK>       — e.g., 0x1
#    <DNS_SERVER>     — e.g., 172.20.0.1
#    <CLIENT_ZONE>    — e.g., iot
#    <PROXY_ZONE>     — e.g., webproxy
#    <VERSION>        — e.g., 7.5 or latest
#
#  Prerequisites:
#    1. SSL Bump CA deployed to /config/containers/squid/ssl_cert/
#    2. Squid config with intercept ports (3129 HTTP, 3131 HTTPS)
#    3. squid-redirect.service installed (see below)
# =====================================================================

# === 1. Container Network ============================================

set container network <NETWORK_NAME> prefix '<PROXY_NETWORK>'

# === 2. Container Definition ==========================================

set container name squid image 'docker.io/jbsky/squid-hardened:<VERSION>'
set container name squid network <NETWORK_NAME> address '<PROXY_IP>'
set container name squid cap-add 'net-admin'
set container name squid memory '512'
set container name squid restart 'on-failure'

# Volumes
set container name squid volume squid-conf source '/config/containers/squid'
set container name squid volume squid-conf destination '/etc/squid'
set container name squid volume squid-ssldb source '/config/containers/squid_ssldb'
set container name squid volume squid-ssldb destination '/var/lib/ssl_db'

# === 3. Firewall Groups ===============================================

set firewall group port-group P_proxy port '3128-3131'
set firewall group port-group all-http port '80'
set firewall group port-group all-http port '443'

# === 4. Policy-Based Routing ==========================================

# 4a. Mark rule (mangle)
set firewall ipv4 name PBR-intercept rule 5 action 'return'
set firewall ipv4 name PBR-intercept rule 5 destination address '<PROXY_NETWORK>'
set firewall ipv4 name PBR-intercept rule 5 description 'Exclude proxy network from PBR'

set firewall ipv4 name PBR-intercept rule 10 action 'accept'
set firewall ipv4 name PBR-intercept rule 10 source address '<CLIENT_SUBNET>'
set firewall ipv4 name PBR-intercept rule 10 protocol 'tcp'
set firewall ipv4 name PBR-intercept rule 10 destination port '80,443'
set firewall ipv4 name PBR-intercept rule 10 set mark '<PBR_MARK>'
set firewall ipv4 name PBR-intercept rule 10 description 'Mark client HTTP/S for transparent intercept'

# 4b. Apply to client interface (prerouting)
set firewall ipv4 prerouting raw rule 10 action 'jump'
set firewall ipv4 prerouting raw rule 10 jump-target 'PBR-intercept'
set firewall ipv4 prerouting raw rule 10 inbound-interface name '<CLIENT_IFACE>'

# 4c. Route table
set protocols static table <PBR_TABLE> route 0.0.0.0/0 next-hop '<PROXY_IP>'

# 4d. Policy route
set policy route PBR-to-proxy rule 10 set table '<PBR_TABLE>'
set policy route PBR-to-proxy rule 10 match mark '<PBR_MARK>'

# 4e. Attach to client interface
set interfaces ethernet <CLIENT_IFACE> policy route 'PBR-to-proxy'

# === 5. Firewall Zones ================================================

set firewall zone <CLIENT_ZONE> interface '<CLIENT_IFACE>'
set firewall zone <CLIENT_ZONE> default-action 'drop'
set firewall zone <CLIENT_ZONE> default-log

set firewall zone <PROXY_ZONE> interface '<PROXY_BRIDGE>'
set firewall zone <PROXY_ZONE> default-action 'drop'
set firewall zone <PROXY_ZONE> default-log

# === 6. Firewall Chains ==============================================

# 6a. Client → Proxy (inbound traffic to squid)
set firewall ipv4 name <CLIENT_ZONE>-to-<PROXY_ZONE> rule 80 action 'accept'
set firewall ipv4 name <CLIENT_ZONE>-to-<PROXY_ZONE> rule 80 protocol 'tcp'
set firewall ipv4 name <CLIENT_ZONE>-to-<PROXY_ZONE> rule 80 destination group port-group 'all-http'
set firewall ipv4 name <CLIENT_ZONE>-to-<PROXY_ZONE> rule 80 description 'PBR intercept HTTP/S'

set firewall ipv4 name <CLIENT_ZONE>-to-<PROXY_ZONE> rule 31280 action 'accept'
set firewall ipv4 name <CLIENT_ZONE>-to-<PROXY_ZONE> rule 31280 protocol 'tcp'
set firewall ipv4 name <CLIENT_ZONE>-to-<PROXY_ZONE> rule 31280 destination group port-group 'P_proxy'
set firewall ipv4 name <CLIENT_ZONE>-to-<PROXY_ZONE> rule 31280 description 'Explicit proxy ports'

set firewall zone <PROXY_ZONE> from <CLIENT_ZONE> firewall name '<CLIENT_ZONE>-to-<PROXY_ZONE>'

# 6b. Proxy → Client (return traffic — CRITICAL: 2 rules needed!)
#     Rule 31280: explicit proxy responses (sport = proxy ports)
set firewall ipv4 name <PROXY_ZONE>-to-<CLIENT_ZONE> rule 31280 action 'accept'
set firewall ipv4 name <PROXY_ZONE>-to-<CLIENT_ZONE> rule 31280 state 'established'
set firewall ipv4 name <PROXY_ZONE>-to-<CLIENT_ZONE> rule 31280 state 'related'
set firewall ipv4 name <PROXY_ZONE>-to-<CLIENT_ZONE> rule 31280 protocol 'tcp'
set firewall ipv4 name <PROXY_ZONE>-to-<CLIENT_ZONE> rule 31280 source group port-group 'P_proxy'
set firewall ipv4 name <PROXY_ZONE>-to-<CLIENT_ZONE> rule 31280 description 'Explicit proxy return'

#     Rule 31281: transparent intercept responses (sport = 80/443, SPOOFED src IP)
set firewall ipv4 name <PROXY_ZONE>-to-<CLIENT_ZONE> rule 31281 action 'accept'
set firewall ipv4 name <PROXY_ZONE>-to-<CLIENT_ZONE> rule 31281 state 'established'
set firewall ipv4 name <PROXY_ZONE>-to-<CLIENT_ZONE> rule 31281 state 'related'
set firewall ipv4 name <PROXY_ZONE>-to-<CLIENT_ZONE> rule 31281 protocol 'tcp'
set firewall ipv4 name <PROXY_ZONE>-to-<CLIENT_ZONE> rule 31281 source group port-group 'all-http'
set firewall ipv4 name <PROXY_ZONE>-to-<CLIENT_ZONE> rule 31281 description 'Intercept transparent return (splice/bump)'

set firewall zone <CLIENT_ZONE> from <PROXY_ZONE> firewall name '<PROXY_ZONE>-to-<CLIENT_ZONE>'

# 6c. Proxy → WAN (squid upstream internet access)
set firewall ipv4 name <PROXY_ZONE>-to-WAN rule 10 action 'accept'
set firewall ipv4 name <PROXY_ZONE>-to-WAN rule 10 state 'established'
set firewall ipv4 name <PROXY_ZONE>-to-WAN rule 10 state 'related'
set firewall ipv4 name <PROXY_ZONE>-to-WAN rule 10 description 'Upstream return traffic'

set firewall ipv4 name <PROXY_ZONE>-to-WAN rule 20 action 'accept'
set firewall ipv4 name <PROXY_ZONE>-to-WAN rule 20 source address '<PROXY_IP>'
set firewall ipv4 name <PROXY_ZONE>-to-WAN rule 20 protocol 'tcp'
set firewall ipv4 name <PROXY_ZONE>-to-WAN rule 20 description 'Squid upstream requests'

# === 7. Commit ========================================================
# commit
# save

# === 8. Post-commit: squid-redirect.service ===========================
#
# Create /config/etc/services/squid-redirect.service with:
#   - ExecStart: nsenter nft REDIRECT rules into container netns
#   - WantedBy=multi-user.target AND WantedBy=vyos-container-squid.service
#
# Then:
#   sudo ln -sf /config/etc/services/squid-redirect.service \
#     /etc/systemd/system/squid-redirect.service
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now squid-redirect.service
#
# See docs/vyos-transparent-proxy.md Step 4 for full service file.

# === 9. Verification ==================================================
#
# sudo nft list chain ip vyos_filter NAME_<PROXY_ZONE>-to-<CLIENT_ZONE>
# PID=$(sudo podman inspect squid --format '{{.State.Pid}}')
# sudo nsenter -t $PID -n nft list ruleset
# sudo nsenter -t $PID -n conntrack -L | grep <CLIENT_SUBNET first octets>
