# =====================================================================
#  Configuration VyOS – PROXY TRANSPARENT (HTTP)
#  Hypothèses :
#    - VyOS 1.4 / 1.5 (Sagitta / Circinus) – syntaxe nftables
#    - Réseau LAN transparent : 192.168.10.0/24 (interface eth1)
#    - Hôte Docker exécutant Squid : 192.168.99.10  (port 3128 intercept)
#    - Interface WAN : eth0
#  Stratégie :
#    - DNAT port 80 sortant du LAN → Squid:3128
#    - HTTPS (443) reste DIRECT (un proxy transparent ne bumpe pas
#      sans CA poussée sur les clients ; pour HTTPS+bump → mode explicite)
#    - Bypass pour l'hôte Squid lui-même + DNS
# =====================================================================

# --- Pré-requis : variables -----------------------------------------
# LAN_IF        = eth1
# LAN_NET       = 192.168.10.0/24
# WAN_IF        = eth0
# SQUID_HOST    = 192.168.99.10
# SQUID_PORT    = 3128

# --- NAT destination : intercept HTTP -------------------------------
set nat destination rule 100 description 'Transparent proxy redirect HTTP'
set nat destination rule 100 inbound-interface name 'eth1'
set nat destination rule 100 source address '192.168.10.0/24'
set nat destination rule 100 destination port '80'
set nat destination rule 100 protocol 'tcp'
set nat destination rule 100 exclude
# ↑ exclude pour éviter une boucle si l'hôte squid est sur le même LAN.
# On commence par exclure le squid lui-même :
set nat destination rule 100 destination address '!192.168.99.10'

set nat destination rule 110 description 'Transparent proxy : HTTP → Squid'
set nat destination rule 110 inbound-interface name 'eth1'
set nat destination rule 110 source address '192.168.10.0/24'
set nat destination rule 110 destination port '80'
set nat destination rule 110 protocol 'tcp'
set nat destination rule 110 translation address '192.168.99.10'
set nat destination rule 110 translation port '3128'

# --- NAT source : pour que les paquets reviennent par VyOS ----------
# Si le squid n'est PAS la gateway des clients, il faut MASQUERADE
# entre VyOS et squid afin que le trafic retour passe par VyOS.
set nat source rule 100 description 'Hairpin pour Squid intercept'
set nat source rule 100 outbound-interface name 'eth1'
# (adapter si squid est dans un autre subnet : remplacer eth1 par eth2 etc.)
set nat source rule 100 destination address '192.168.99.10'
set nat source rule 100 destination port '3128'
set nat source rule 100 protocol 'tcp'
set nat source rule 100 translation address 'masquerade'

# --- Firewall : autoriser le flux LAN → SQUID:3128 ------------------
set firewall ipv4 name LAN-TO-PROXY default-action 'accept'
set firewall ipv4 name LAN-TO-PROXY rule 10 action 'accept'
set firewall ipv4 name LAN-TO-PROXY rule 10 destination address '192.168.99.10'
set firewall ipv4 name LAN-TO-PROXY rule 10 destination port '3128'
set firewall ipv4 name LAN-TO-PROXY rule 10 protocol 'tcp'

# --- Bypass DNS (sinon casse la résolution côté squid) --------------
# Si VyOS fait le forwarder DNS, rien à faire.
# Sinon, autoriser 53 vers les resolvers publics depuis tout le LAN.
set firewall ipv4 name LAN-OUT rule 20 action 'accept'
set firewall ipv4 name LAN-OUT rule 20 protocol 'udp'
set firewall ipv4 name LAN-OUT rule 20 destination port '53'

# --- HTTPS direct (pas de bump en transparent) ----------------------
set firewall ipv4 name LAN-OUT rule 30 action 'accept'
set firewall ipv4 name LAN-OUT rule 30 protocol 'tcp'
set firewall ipv4 name LAN-OUT rule 30 destination port '443'

# --- Application ----------------------------------------------------
# Lier la chaîne au routage forward :
set firewall ipv4 forward filter rule 100 action 'jump'
set firewall ipv4 forward filter rule 100 jump-target 'LAN-OUT'
set firewall ipv4 forward filter rule 100 inbound-interface name 'eth1'

# --- Logging du DNAT (utile en debug) -------------------------------
set nat destination rule 110 log

# =====================================================================
#  Commit / Save :
#    commit
#    save
# =====================================================================
