# =====================================================================
#  Configuration VyOS – PROXY EXPLICITE + SSL BUMP
#  Hypothèses :
#    - VyOS 1.4 / 1.5
#    - LAN explicite : 192.168.20.0/24 (interface eth2)
#    - Hôte Docker Squid : 192.168.99.10 ports 3128 (HTTP) / 3129 (SSL Bump)
#    - Les clients sont configurés via DHCP option 252 (WPAD) /
#      profil MDM / GPO pour utiliser le proxy
#  Stratégie :
#    - PAS de DNAT : les clients adressent Squid explicitement
#    - VyOS filtre : seul Squid peut sortir en 80/443 vers Internet
#    - Les clients NE peuvent PAS sortir directement en 80/443
#      (force l'usage du proxy = pas de contournement)
#    - DHCP pousse WPAD + DNS local
# =====================================================================

# --- Variables --------------------------------------------------------
# LAN_IF       = eth2
# LAN_NET      = 192.168.20.0/24
# SQUID_HOST   = 192.168.99.10
# SQUID_HTTP   = 3128
# SQUID_BUMP   = 3129

# --- DHCP : pousser le proxy via option 252 (WPAD) -------------------
set service dhcp-server shared-network-name LAN-EXPLICIT subnet 192.168.20.0/24 default-router '192.168.20.1'
set service dhcp-server shared-network-name LAN-EXPLICIT subnet 192.168.20.0/24 name-server '192.168.20.1'
set service dhcp-server shared-network-name LAN-EXPLICIT subnet 192.168.20.0/24 range 0 start '192.168.20.50'
set service dhcp-server shared-network-name LAN-EXPLICIT subnet 192.168.20.0/24 range 0 stop '192.168.20.200'
# Option WPAD (252) – Squid sert un wpad.dat ou un serveur web le sert
set service dhcp-server shared-network-name LAN-EXPLICIT subnet 192.168.20.0/24 option vendor-option 252 'string "http://wpad.lan.local/wpad.dat"'

# --- DNS local : wpad.lan.local pointe vers le serveur WPAD ----------
set service dns forwarding allow-from '192.168.20.0/24'
set service dns forwarding listen-address '192.168.20.1'
# Ajouter un host static pour wpad
set system static-host-mapping host-name wpad.lan.local inet '192.168.99.10'

# --- Firewall : autoriser uniquement Squid à sortir en 80/443 -------
set firewall ipv4 name LAN-EXPLICIT-OUT default-action 'drop'

# Autoriser DNS vers le forwarder VyOS
set firewall ipv4 name LAN-EXPLICIT-OUT rule 10 action 'accept'
set firewall ipv4 name LAN-EXPLICIT-OUT rule 10 destination address '192.168.20.1'
set firewall ipv4 name LAN-EXPLICIT-OUT rule 10 destination port '53'
set firewall ipv4 name LAN-EXPLICIT-OUT rule 10 protocol 'tcp_udp'

# Autoriser DHCP
set firewall ipv4 name LAN-EXPLICIT-OUT rule 20 action 'accept'
set firewall ipv4 name LAN-EXPLICIT-OUT rule 20 destination port '67-68'
set firewall ipv4 name LAN-EXPLICIT-OUT rule 20 protocol 'udp'

# Autoriser les clients à JOINDRE le proxy Squid
set firewall ipv4 name LAN-EXPLICIT-OUT rule 30 action 'accept'
set firewall ipv4 name LAN-EXPLICIT-OUT rule 30 destination address '192.168.99.10'
set firewall ipv4 name LAN-EXPLICIT-OUT rule 30 destination port '3128,3129'
set firewall ipv4 name LAN-EXPLICIT-OUT rule 30 protocol 'tcp'

# BLOQUER toute autre sortie HTTP/HTTPS depuis le LAN
set firewall ipv4 name LAN-EXPLICIT-OUT rule 100 action 'reject'
set firewall ipv4 name LAN-EXPLICIT-OUT rule 100 destination port '80,443,8080,8443'
set firewall ipv4 name LAN-EXPLICIT-OUT rule 100 protocol 'tcp'
set firewall ipv4 name LAN-EXPLICIT-OUT rule 100 log

# --- Firewall : autoriser Squid lui-même à sortir vers le Web -------
set firewall ipv4 name PROXY-OUT default-action 'drop'
set firewall ipv4 name PROXY-OUT rule 10 action 'accept'
set firewall ipv4 name PROXY-OUT rule 10 source address '192.168.99.10'
set firewall ipv4 name PROXY-OUT rule 10 destination port '80,443'
set firewall ipv4 name PROXY-OUT rule 10 protocol 'tcp'
set firewall ipv4 name PROXY-OUT rule 20 action 'accept'
set firewall ipv4 name PROXY-OUT rule 20 source address '192.168.99.10'
set firewall ipv4 name PROXY-OUT rule 20 destination port '53'
set firewall ipv4 name PROXY-OUT rule 20 protocol 'tcp_udp'

# --- Liaison aux interfaces forward --------------------------------
set firewall ipv4 forward filter rule 200 action 'jump'
set firewall ipv4 forward filter rule 200 jump-target 'LAN-EXPLICIT-OUT'
set firewall ipv4 forward filter rule 200 inbound-interface name 'eth2'

set firewall ipv4 forward filter rule 210 action 'jump'
set firewall ipv4 forward filter rule 210 jump-target 'PROXY-OUT'
set firewall ipv4 forward filter rule 210 source address '192.168.99.10'

# --- NAT source pour Squid → Internet --------------------------------
set nat source rule 200 description 'Squid SNAT vers WAN'
set nat source rule 200 outbound-interface name 'eth0'
set nat source rule 200 source address '192.168.99.10'
set nat source rule 200 translation address 'masquerade'

# =====================================================================
#  Notes opérationnelles :
#    - Distribuer le bump.crt (certs/bump.crt) sur tous les clients
#      du LAN 192.168.20.0/24 via GPO, MDM, Ansible, etc.
#    - Sans CA installée, les utilisateurs verront une erreur TLS.
#    - Le fichier wpad.dat doit être servi par un nginx ou par Squid
#      (cf docs/wpad-example.dat).
#  Commit / Save :
#    commit
#    save
# =====================================================================
